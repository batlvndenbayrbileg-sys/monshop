# PostgreSQL connection string (Neon, Vercel Postgres, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT signing secret — use a long random string (32+ chars)
JWT_SECRET="change-this-to-a-secure-random-string-min-32-chars"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Public site URL — used to build payment return URLs (no trailing slash)
NEXT_PUBLIC_SITE_URL="https://mon-cosmetics.shop"

# Wire Payment (https://wire.mn). Leave WIRE_SECRET_KEY empty to run in MOCK mode
# (full flow works locally, intents auto-succeed after ~5s). sk_test_… = test,
# sk_live_… = production.
WIRE_SECRET_KEY=""
# Webhook signing secret from the Wire dashboard (whsec_…)
WIRE_WEBHOOK_SECRET=""
